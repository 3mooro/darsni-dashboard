---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | لوحة تحكم درسني</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body class="bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-50 antialiased min-h-screen flex">
    
    <!-- Sidebar -->
    <aside class="w-72 bg-slate-950 text-white flex-shrink-0 flex flex-col border-l border-slate-800 relative z-20 shadow-2xl">
      <div class="p-6 border-b border-slate-800 flex items-center gap-3">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500 to-indigo-600 flex items-center justify-center font-black text-2xl shadow-lg shadow-purple-500/30">
          D
        </div>
        <div>
          <h2 class="font-bold text-xl leading-tight">درسني</h2>
          <span class="text-xs text-purple-400 font-semibold tracking-wider uppercase">الإدارة</span>
        </div>
      </div>
      
      <nav class="flex-1 p-4 flex flex-col gap-2">
        {
          [
            { href: '/', label: 'نظرة عامة' },
            { href: '/courses', label: 'إدارة الدورات' },
            { href: '/students', label: 'الطلاب والطلبات' },
            { href: '/blog', label: 'المدونة والمقالات' },
            { href: 'https://darsni-site.pages.dev', label: 'زيارة الموقع ↗', extraClass: 'mt-auto bg-slate-900/50 text-purple-400 hover:bg-purple-900/50', target: '_blank' },
            { href: '/settings', label: 'إعدادات الموقع' }
          ].map(link => {
            // Check if current path matches the link href. Handle trailing slashes.
            const isActive = Astro.url.pathname === link.href || (link.href !== '/' && !link.href.startsWith('http') && Astro.url.pathname.startsWith(link.href));
            return (
              <a 
                href={link.href} 
                target={link.target || '_self'}
                class={`flex items-center gap-3 px-4 py-3.5 rounded-xl transition-all ${link.extraClass || ''} ${
                  isActive 
                    ? 'bg-purple-600 text-white font-bold shadow-lg shadow-purple-600/20' 
                    : 'hover:bg-slate-800 text-slate-300 hover:text-white font-semibold'
                }`}
              >
                {link.label}
              </a>
            );
          })
        }
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col min-h-screen overflow-hidden relative z-10">
      <!-- Header -->
      <header class="h-20 bg-white/70 dark:bg-slate-900/70 backdrop-blur-xl border-b border-slate-200 dark:border-slate-800 flex items-center justify-between px-8 sticky top-0 z-30">
        <h1 class="text-2xl font-black text-slate-800 dark:text-white">{title}</h1>
        <div class="flex items-center gap-4">
          <button class="w-10 h-10 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 flex items-center justify-center hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors shadow-sm">
            🔔
          </button>
          <div class="flex items-center gap-3 pl-4 border-r border-slate-200 dark:border-slate-700">
            <div class="text-left hidden sm:block">
              <p class="text-sm font-bold leading-tight">المدير العام</p>
              <p class="text-xs text-slate-500 dark:text-slate-400">admin@darsni.com</p>
            </div>
            <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-purple-500 to-rose-500 flex items-center justify-center font-bold text-white shadow-md">
              A
            </div>
          </div>
        </div>
      </header>
      
      <!-- Content -->
      <div class="flex-1 overflow-auto p-8 relative">
        <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-purple-100/40 via-slate-50 to-slate-50 dark:from-purple-900/10 dark:via-slate-950 dark:to-slate-950"></div>
        <div class="max-w-7xl mx-auto">
          <slot />
        </div>
      </div>
    </main>
  </body>
</html>
