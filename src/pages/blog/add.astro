---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="إضافة مقال جديد - لوحة التحكم">
  <div class="flex flex-col gap-8 w-full max-w-4xl mx-auto">
    <!-- Header -->
    <div>
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white font-cairo">إضافة مقال جديد</h1>
      <p class="text-slate-500 dark:text-slate-400 mt-1">اكتب مقالاً جديداً لمشاركته مع زوار المنصة والطلاب</p>
    </div>

    <!-- Form Container -->
    <div class="bg-white dark:bg-slate-900 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-sm p-6 sm:p-8">
      <form class="flex flex-col gap-6" onsubmit="event.preventDefault(); alert('تم حفظ المقال بنجاح!');">
        <!-- Title Input -->
        <div class="flex flex-col gap-2">
          <label for="title" class="text-sm font-medium text-slate-700 dark:text-slate-300">عنوان المقال</label>
          <input type="text" id="title" name="title" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-purple-500/20 focus:border-purple-500 transition-all placeholder:text-slate-400" placeholder="اكتب عنواناً جذاباً لمقالك..." required>
        </div>

        <div class="flex flex-col gap-2">
          <label for="tags" class="text-sm font-medium text-slate-700 dark:text-slate-300">الكلمات المفتاحية (Tags)</label>
          <input type="text" id="tags" name="tags" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-purple-500/20 focus:border-purple-500 transition-all placeholder:text-slate-400" placeholder="مثال: برمجة, تعليم, تقنية (مفصولة بفاصلة)">
        </div>

        <!-- Rich Text Description (Quill) -->
        <div class="flex flex-col gap-2" dir="ltr">
          <div class="flex justify-end" dir="rtl">
            <label class="text-sm font-medium text-slate-700 dark:text-slate-300">محتوى المقال</label>
          </div>
          <div class="rounded-xl overflow-hidden border border-slate-200 dark:border-slate-700 focus-within:ring-2 focus-within:ring-purple-500/20 focus-within:border-purple-500 transition-all bg-slate-50 dark:bg-slate-800">
            <div id="blog-editor-container" class="h-96 text-slate-900 dark:text-white !border-none" dir="rtl"></div>
          </div>
          <input type="hidden" name="content" id="content_input">
        </div>

        <!-- Image Upload -->
        <div class="flex flex-col gap-2">
          <label class="text-sm font-medium text-slate-700 dark:text-slate-300">صورة المقال الرئيسية</label>
          <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-slate-300 dark:border-slate-700 border-dashed rounded-xl hover:border-purple-500 hover:bg-purple-50/50 dark:hover:bg-purple-500/5 transition-all cursor-pointer">
            <div class="space-y-1 text-center">
              <svg class="mx-auto h-12 w-12 text-slate-400" stroke="currentColor" fill="none" viewBox="0 0 48 48" aria-hidden="true">
                <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <div class="flex text-sm text-slate-600 dark:text-slate-400 justify-center">
                <label for="blog-image" class="relative cursor-pointer bg-transparent rounded-md font-medium text-purple-600 hover:text-purple-500 focus-within:outline-none focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-purple-500">
                  <span>ارفع ملفاً</span>
                  <input id="blog-image" name="blog-image" type="file" class="sr-only">
                </label>
                <p class="pr-1">أو اسحب وافلت هنا</p>
              </div>
              <p class="text-xs text-slate-500 dark:text-slate-500">
                أبعاد مستحسنة 1200x630px
              </p>
            </div>
          </div>
        </div>

        <!-- Actions -->
        <div class="pt-4 flex justify-between gap-4 border-t border-slate-100 dark:border-slate-800 mt-2">
          <button type="button" class="px-6 py-3 rounded-xl font-medium text-slate-600 dark:text-slate-400 border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
            حفظ كمسودة
          </button>
          <div class="flex gap-4">
            <a href="/blog" class="px-6 py-3 rounded-xl font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">إلغاء</a>
            <button type="submit" class="bg-gradient-to-r from-purple-600 to-indigo-500 hover:from-purple-700 hover:to-indigo-600 text-white px-8 py-3 rounded-xl font-medium transition-all shadow-lg shadow-purple-500/25 hover:shadow-purple-500/40">
              نشر المقال
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<!-- Quill Styles & Script -->
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<style is:global>
  .ql-toolbar {
    border: none !important;
    border-bottom: 1px solid var(--fallback-bc, #e2e8f0) !important;
    background-color: transparent !important;
    border-radius: 0.75rem 0.75rem 0 0 !important;
    direction: ltr; 
    text-align: left;
  }
  .dark .ql-toolbar {
    border-bottom-color: #334155 !important;
  }
  .ql-container {
    border: none !important;
    font-family: inherit !important;
    font-size: 1.05rem !important;
    line-height: 1.8 !important;
  }
  .dark .ql-editor.ql-blank::before {
    color: #94a3b8 !important;
  }
  .dark .ql-snow .ql-stroke {
    stroke: #cbd5e1 !important;
  }
  .dark .ql-snow .ql-fill, .dark .ql-snow .ql-stroke.ql-fill {
    fill: #cbd5e1 !important;
  }
  .dark .ql-snow .ql-picker {
    color: #cbd5e1 !important;
  }
</style>
<script is:inline src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<script is:inline>
  document.addEventListener("DOMContentLoaded", function() {
    var quill = new Quill('#blog-editor-container', {
      theme: 'snow',
      modules: {
        toolbar: [
          [{ 'header': [1, 2, 3, 4, false] }],
          ['bold', 'italic', 'underline', 'strike', 'blockquote', 'code-block'],
          [{ 'list': 'ordered'}, { 'list': 'bullet' }],
          ['link', 'image', 'video'],
          [{ 'align': [] }],
          [{ 'color': [] }, { 'background': [] }],
          ['clean'],
          [{ 'direction': 'rtl' }]
        ]
      },
      placeholder: 'ابدأ بكتابة مقالك الرائع هنا...'
    });
    
    quill.format('direction', 'rtl');
    quill.format('align', 'right');

    const form = document.querySelector('form');
    form.addEventListener('submit', function() {
      document.querySelector('#content_input').value = quill.root.innerHTML;
    });
  });
</script>
