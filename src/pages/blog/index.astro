---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

let posts = [];
try {
  const { env } = await import('cloudflare:workers');
  const db = env?.DB;
  if (db) {
    const { results } = await db.prepare('SELECT * FROM blog_posts ORDER BY created_at DESC').all();
    posts = results || [];
  } else {
    posts = [
      { id: 1, title: 'كيف تبدأ تعلم البرمجة', author: 'أحمد الإدارة', views: 1250, status: 'منشور', date: '2023-05-12' },
      { id: 2, title: 'أهم 10 نصائح للنجاح في الامتحانات', author: 'سارة الإدارة', views: 890, status: 'منشور', date: '2023-06-01' },
      { id: 3, title: 'تحديثات المنصة الجديدة لعام 2024', author: 'فريق التطوير', views: 0, status: 'مسودة', date: '2023-06-15' },
    ];
  }
} catch (e) {
  console.error(e);
}
---

<DashboardLayout title="المدونة - لوحة التحكم">
  <div class="flex flex-col gap-8 w-full max-w-7xl mx-auto">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <div>
        <h1 class="text-3xl font-bold text-slate-900 dark:text-white font-cairo">إدارة المدونة</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">عرض وإدارة المقالات والأخبار المنشورة</p>
      </div>
      <a href="/blog/add" class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-purple-600 to-indigo-500 hover:from-purple-700 hover:to-indigo-600 text-white px-6 py-3 rounded-2xl font-medium transition-all shadow-lg shadow-purple-500/25 hover:shadow-purple-500/40">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        إضافة مقال جديد
      </a>
    </div>

    <!-- Table Section -->
    <div class="bg-white dark:bg-slate-900 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-sm overflow-hidden">
      <div class="p-6 border-b border-slate-100 dark:border-slate-800 flex justify-between items-center bg-slate-50/50 dark:bg-slate-800/20">
        <h2 class="text-lg font-semibold text-slate-800 dark:text-slate-200">قائمة المقالات</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-right border-collapse">
          <thead>
            <tr class="bg-slate-50/50 dark:bg-slate-800/20 border-b border-slate-100 dark:border-slate-800">
              <th class="py-4 px-6 text-sm font-medium text-slate-500 dark:text-slate-400">عنوان المقال</th>
              <th class="py-4 px-6 text-sm font-medium text-slate-500 dark:text-slate-400">الكاتب</th>
              <th class="py-4 px-6 text-sm font-medium text-slate-500 dark:text-slate-400">المشاهدات</th>
              <th class="py-4 px-6 text-sm font-medium text-slate-500 dark:text-slate-400">الحالة</th>
              <th class="py-4 px-6 text-sm font-medium text-slate-500 dark:text-slate-400">تاريخ النشر</th>
              <th class="py-4 px-6 text-sm font-medium text-slate-500 dark:text-slate-400">إجراءات</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
            {posts.map((post) => (
              <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors group">
                <td class="py-4 px-6">
                  <div class="font-semibold text-slate-900 dark:text-white max-w-xs truncate" title={post.title}>{post.title}</div>
                </td>
                <td class="py-4 px-6 text-slate-600 dark:text-slate-300 font-medium">{post.author}</td>
                <td class="py-4 px-6 text-slate-600 dark:text-slate-300">
                  <div class="flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                    {post.views.toLocaleString()}
                  </div>
                </td>
                <td class="py-4 px-6">
                  <span class={`inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium ${post.status === 'منشور' ? 'bg-indigo-100 text-indigo-800 dark:bg-indigo-500/20 dark:text-indigo-400' : 'bg-slate-100 text-slate-800 dark:bg-slate-700/50 dark:text-slate-400'}`}>
                    {post.status}
                  </span>
                </td>
                <td class="py-4 px-6 text-slate-600 dark:text-slate-300">
                  {new Date(post.date).toLocaleDateString('ar-EG')}
                </td>
                <td class="py-4 px-6">
                  <div class="flex items-center gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                    <button class="text-slate-400 hover:text-indigo-500 transition-colors" title="تعديل">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    </button>
                    <button class="text-slate-400 hover:text-red-500 transition-colors" title="حذف">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                    </button>
                  </div>
                </td>
              </tr>
            ))}
            {posts.length === 0 && (
              <tr>
                <td colspan="6" class="py-12 text-center text-slate-500 dark:text-slate-400">لا توجد مقالات متاحة حالياً.</td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</DashboardLayout>
