---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
let success = false;
let error = '';

if (Astro.request.method === 'POST') {
  try {
    const { env } = await import('cloudflare:workers');
    const db = env?.DB;
    if (db) {
      const data = await Astro.request.formData();
      const title = data.get('title') as string;
      const category = data.get('category') as string;
      const description = data.get('description') as string;
      const slug = title.trim().replace(/\s+/g, '-');
      const image = 'https://placehold.co/600x400/9333ea/ffffff?text=' + encodeURIComponent(title);
      
      await db.prepare(`
        INSERT INTO courses (slug, title, instructor, rating, image, tag, level, body)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?)
      `).bind(slug, title, 'أكاديمية درسني', 5.0, image, 'جديد', category, description).run();
      
      success = true;
    } else {
      error = 'قاعدة البيانات غير متصلة';
    }
  } catch (e: any) {
    console.error(e);
    error = 'حدث خطأ: ' + e.message;
  }
}
---

<DashboardLayout title="إضافة دورة جديدة - لوحة التحكم">
  <div class="flex flex-col gap-8 w-full max-w-4xl mx-auto">
    <!-- Header -->
    <div>
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white font-cairo">إضافة دورة جديدة</h1>
      <p class="text-slate-500 dark:text-slate-400 mt-1">أدخل تفاصيل الدورة الجديدة لنشرها للطلاب</p>
    </div>

    {success && (
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-xl relative" role="alert">
        <strong class="font-bold">نجاح!</strong>
        <span class="block sm:inline"> تم إضافة الدورة بنجاح.</span>
      </div>
    )}
    {error && (
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-xl relative" role="alert">
        <strong class="font-bold">خطأ!</strong>
        <span class="block sm:inline"> {error}</span>
      </div>
    )}

    <!-- Form Container -->
    <div class="bg-white dark:bg-slate-900 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-sm p-6 sm:p-8">
      <form method="POST" class="flex flex-col gap-6">
        <!-- Title Input -->
        <div class="flex flex-col gap-2">
          <label for="title" class="text-sm font-medium text-slate-700 dark:text-slate-300">عنوان الدورة</label>
          <input type="text" id="title" name="title" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-purple-500/20 focus:border-purple-500 transition-all placeholder:text-slate-400" placeholder="مثال: دورة الرياضيات المتقدمة" required>
        </div>

        <!-- Category -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label for="category" class="text-sm font-medium text-slate-700 dark:text-slate-300">المرحلة الدراسية</label>
            <select id="category" name="category" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-purple-500/20 focus:border-purple-500 transition-all appearance-none" required>
              <option value="" disabled selected>اختر المرحلة...</option>
              <option value="primary">الابتدائي</option>
              <option value="middle">المتوسط</option>
              <option value="secondary">الثانوي</option>
              <option value="university">الجامعي</option>
            </select>
          </div>
        </div>

        <!-- Rich Text Description (Quill) -->
        <div class="flex flex-col gap-2" dir="ltr">
          <div class="flex justify-end" dir="rtl">
            <label class="text-sm font-medium text-slate-700 dark:text-slate-300">وصف الدورة (المحتوى)</label>
          </div>
          <div class="rounded-xl overflow-hidden border border-slate-200 dark:border-slate-700 focus-within:ring-2 focus-within:ring-purple-500/20 focus-within:border-purple-500 transition-all bg-slate-50 dark:bg-slate-800">
            <div id="editor-container" class="h-64 text-slate-900 dark:text-white !border-none" dir="rtl"></div>
          </div>
          <input type="hidden" name="description" id="description_input">
        </div>

        <!-- Actions -->
        <div class="pt-4 flex justify-end gap-4 border-t border-slate-100 dark:border-slate-800 mt-2">
          <a href="/courses" class="px-6 py-3 rounded-xl font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">العودة للوراء</a>
          <button type="submit" class="bg-gradient-to-r from-purple-600 to-indigo-500 hover:from-purple-700 hover:to-indigo-600 text-white px-8 py-3 rounded-xl font-medium transition-all shadow-lg shadow-purple-500/25 hover:shadow-purple-500/40">
            حفظ الدورة
          </button>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<!-- Quill Styles & Script -->
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<style is:global>
  .ql-toolbar {
    border: none !important;
    border-bottom: 1px solid var(--fallback-bc, #e2e8f0) !important;
    background-color: transparent !important;
    border-radius: 0.75rem 0.75rem 0 0 !important;
    direction: ltr;
    text-align: left;
  }
  .dark .ql-toolbar { border-bottom-color: #334155 !important; }
  .ql-container { border: none !important; font-family: inherit !important; font-size: 1rem !important; }
  .dark .ql-editor.ql-blank::before { color: #94a3b8 !important; }
  .dark .ql-snow .ql-stroke { stroke: #cbd5e1 !important; }
  .dark .ql-snow .ql-fill, .dark .ql-snow .ql-stroke.ql-fill { fill: #cbd5e1 !important; }
  .dark .ql-snow .ql-picker { color: #cbd5e1 !important; }
</style>
<script is:inline src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<script is:inline>
  document.addEventListener("DOMContentLoaded", function() {
    var quill = new Quill('#editor-container', {
      theme: 'snow',
      modules: {
        toolbar: [
          [{ 'header': [1, 2, 3, false] }],
          ['bold', 'italic', 'underline', 'strike'],
          [{ 'list': 'ordered'}, { 'list': 'bullet' }],
          ['link'],
          [{ 'align': [] }],
          ['clean'],
          [{ 'direction': 'rtl' }]
        ]
      },
      placeholder: 'اكتب وصفاً مفصلاً للدورة هنا...'
    });
    
    quill.format('direction', 'rtl');
    quill.format('align', 'right');

    const form = document.querySelector('form');
    form.addEventListener('submit', function() {
      document.querySelector('#description_input').value = quill.root.innerHTML;
    });
  });
</script>
