---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="نظرة عامة">
  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">
    
    <!-- Stat 1 -->
    <div class="bg-white dark:bg-slate-900 rounded-3xl p-6 border border-slate-100 dark:border-slate-800 shadow-xl shadow-slate-200/50 dark:shadow-none relative overflow-hidden group hover:border-purple-300 dark:hover:border-purple-500/50 transition-colors cursor-pointer">
      <div class="absolute -top-4 -right-4 w-32 h-32 bg-purple-500/5 rounded-full blur-2xl group-hover:bg-purple-500/20 transition-colors duration-500"></div>
      <div class="flex justify-between items-start relative z-10">
        <div>
          <p class="text-slate-500 dark:text-slate-400 text-sm font-bold mb-2">إجمالي الطلاب</p>
          <h3 class="text-4xl font-black text-slate-900 dark:text-white tracking-tight">10,234</h3>
        </div>
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-purple-100 to-purple-50 dark:from-purple-900/40 dark:to-purple-900/10 text-purple-600 dark:text-purple-400 flex items-center justify-center text-2xl shadow-inner border border-purple-200/50 dark:border-purple-800/50">
          👥
        </div>
      </div>
      <div class="mt-5 flex items-center text-sm font-semibold relative z-10">
        <span class="text-emerald-500 bg-emerald-50 dark:bg-emerald-500/10 px-2 py-0.5 rounded-md ml-2">↑ 12%</span>
        <span class="text-slate-400">منذ الشهر الماضي</span>
      </div>
    </div>

    <!-- Stat 2 -->
    <div class="bg-white dark:bg-slate-900 rounded-3xl p-6 border border-slate-100 dark:border-slate-800 shadow-xl shadow-slate-200/50 dark:shadow-none relative overflow-hidden group hover:border-indigo-300 dark:hover:border-indigo-500/50 transition-colors cursor-pointer">
      <div class="absolute -top-4 -right-4 w-32 h-32 bg-indigo-500/5 rounded-full blur-2xl group-hover:bg-indigo-500/20 transition-colors duration-500"></div>
      <div class="flex justify-between items-start relative z-10">
        <div>
          <p class="text-slate-500 dark:text-slate-400 text-sm font-bold mb-2">الدورات النشطة</p>
          <h3 class="text-4xl font-black text-slate-900 dark:text-white tracking-tight">24</h3>
        </div>
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-indigo-100 to-indigo-50 dark:from-indigo-900/40 dark:to-indigo-900/10 text-indigo-600 dark:text-indigo-400 flex items-center justify-center text-2xl shadow-inner border border-indigo-200/50 dark:border-indigo-800/50">
          📚
        </div>
      </div>
      <div class="mt-5 flex items-center text-sm font-semibold relative z-10">
        <span class="text-indigo-500 bg-indigo-50 dark:bg-indigo-500/10 px-2 py-0.5 rounded-md ml-2">+ 3</span>
        <span class="text-slate-400">دورات جديدة أضيفت</span>
      </div>
    </div>

    <!-- Stat 3 -->
    <div class="bg-white dark:bg-slate-900 rounded-3xl p-6 border border-slate-100 dark:border-slate-800 shadow-xl shadow-slate-200/50 dark:shadow-none relative overflow-hidden group hover:border-rose-300 dark:hover:border-rose-500/50 transition-colors cursor-pointer">
      <div class="absolute -top-4 -right-4 w-32 h-32 bg-rose-500/5 rounded-full blur-2xl group-hover:bg-rose-500/20 transition-colors duration-500"></div>
      <div class="flex justify-between items-start relative z-10">
        <div>
          <p class="text-slate-500 dark:text-slate-400 text-sm font-bold mb-2">طلبات التواصل</p>
          <h3 class="text-4xl font-black text-slate-900 dark:text-white tracking-tight">128</h3>
        </div>
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-rose-100 to-rose-50 dark:from-rose-900/40 dark:to-rose-900/10 text-rose-600 dark:text-rose-400 flex items-center justify-center text-2xl shadow-inner border border-rose-200/50 dark:border-rose-800/50">
          💬
        </div>
      </div>
      <div class="mt-5 flex items-center text-sm font-semibold relative z-10">
        <span class="text-rose-600 bg-rose-50 dark:bg-rose-500/10 px-2 py-0.5 rounded-md ml-2">• 5</span>
        <span class="text-slate-400">طلبات تحتاج مراجعة</span>
      </div>
    </div>

    <!-- Stat 4 -->
    <div class="bg-white dark:bg-slate-900 rounded-3xl p-6 border border-slate-100 dark:border-slate-800 shadow-xl shadow-slate-200/50 dark:shadow-none relative overflow-hidden group hover:border-emerald-300 dark:hover:border-emerald-500/50 transition-colors cursor-pointer">
      <div class="absolute -top-4 -right-4 w-32 h-32 bg-emerald-500/5 rounded-full blur-2xl group-hover:bg-emerald-500/20 transition-colors duration-500"></div>
      <div class="flex justify-between items-start relative z-10">
        <div>
          <p class="text-slate-500 dark:text-slate-400 text-sm font-bold mb-2">الزيارات الشهرية</p>
          <h3 class="text-4xl font-black text-slate-900 dark:text-white tracking-tight">45.2K</h3>
        </div>
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-emerald-100 to-emerald-50 dark:from-emerald-900/40 dark:to-emerald-900/10 text-emerald-600 dark:text-emerald-400 flex items-center justify-center text-2xl shadow-inner border border-emerald-200/50 dark:border-emerald-800/50">
          📈
        </div>
      </div>
      <div class="mt-5 flex items-center text-sm font-semibold relative z-10">
        <span class="text-emerald-500 bg-emerald-50 dark:bg-emerald-500/10 px-2 py-0.5 rounded-md ml-2">↑ 24%</span>
        <span class="text-slate-400">مقارنة بالشهر الماضي</span>
      </div>
    </div>
  </div>

  <div class="bg-white dark:bg-slate-900 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-xl shadow-slate-200/30 dark:shadow-none overflow-hidden relative">
    <div class="p-6 border-b border-slate-100 dark:border-slate-800 flex justify-between items-center bg-slate-50/50 dark:bg-slate-900/50">
      <h3 class="text-lg font-black text-slate-800 dark:text-white">أحدث طلبات التسجيل</h3>
      <button class="text-sm text-purple-600 dark:text-purple-400 font-bold hover:underline">عرض الكل ←</button>
    </div>
    <div class="p-12 text-center text-slate-500">
      <div class="w-20 h-20 bg-slate-100 dark:bg-slate-800 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl">
        📭
      </div>
      <h4 class="text-lg font-bold text-slate-700 dark:text-slate-300 mb-2">لا توجد طلبات جديدة</h4>
      <p class="text-sm">سيتم عرض أحدث الطلبات والتسجيلات هنا فور وصولها.</p>
    </div>
  </div>
</DashboardLayout>
